# ============================================
# DevOps Agent — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Mode ──────────────────────────────────────
# Set to "true" to use mock/simulated responses (no real API calls)
SIMULATION_MODE=true
DEBUG=true
LOG_LEVEL=INFO

# ── LLM Configuration ────────────────────────
# Choose your LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Model names
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4-turbo-preview

# ── Database ──────────────────────────────────
DATABASE_URL=sqlite:///./devops_agent.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/devops_agent

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Configuration ────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-api-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── GitHub Integration ────────────────────────
GITHUB_TOKEN=your-github-token-here
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_DEFAULT_ORG=your-org

# ── Docker ────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password

# ── Kubernetes ────────────────────────────────
KUBECONFIG_PATH=~/.kube/config
K8S_DEFAULT_NAMESPACE=default

# ── Terraform ─────────────────────────────────
TERRAFORM_WORKSPACE=default
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_DEFAULT_REGION=us-east-1

# ── Monitoring ────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-key
ALERTMANAGER_URL=http://localhost:9093

# ── Notifications ─────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#devops-alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
PAGERDUTY_API_KEY=your-pagerduty-key

# ── Security ──────────────────────────────────
TRIVY_SEVERITY=HIGH,CRITICAL
SECRET_SCANNING_ENABLED=true

# ── Agent Settings ────────────────────────────
AGENT_MAX_ITERATIONS=15
AGENT_TIMEOUT_SECONDS=300
AGENT_MEMORY_COLLECTION=incident_history
CHROMA_PERSIST_DIR=./data/chromadb
